{
  "name": "sheet-agent",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm -r --parallel --filter \"@sheet-agent/*\" run dev",
    "dev:web": "pnpm --filter @sheet-agent/web dev",
    "dev:api": "pnpm --filter @sheet-agent/api start:dev",
    "build": "pnpm -r run build",
    "db:generate": "pnpm --filter @sheet-agent/db prisma generate",
    "db:push": "pnpm --filter @sheet-agent/db prisma db push",
    "db:studio": "pnpm --filter @sheet-agent/db prisma studio"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
