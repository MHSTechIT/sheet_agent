{
  "name": "sheet-agent",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "backend",
    "frontend",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:web": "npm run dev -w @sheet-agent/web",
    "dev:api": "npm run start:dev -w @sheet-agent/api",
    "build": "npm run build --workspaces --if-present",
    "db:generate": "npm run prisma -w @sheet-agent/db -- generate",
    "db:push": "npm run prisma -w @sheet-agent/db -- db push",
    "db:studio": "npm run prisma -w @sheet-agent/db -- studio"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.6.3"
  }
}
