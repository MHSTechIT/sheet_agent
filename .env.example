# =========================================================
# Application encryption key (32 random bytes, base64)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# =========================================================
APP_ENC_KEY="REPLACE_WITH_BASE64_32_BYTES"

# =========================================================
# NestJS API (backend/)
# =========================================================
API_PORT=4000
API_HOST=0.0.0.0
WEB_ORIGIN=http://localhost:3000

# Where JSON state files live. Default: <repo-root>/data
# DATA_DIR=/var/lib/sheet-agent

# Owner login (the only account; password-only sign in)
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=change-me

# JWT
JWT_SECRET="REPLACE_WITH_LONG_RANDOM_STRING"
JWT_EXPIRES_IN=7d

# =========================================================
# Meta (Facebook Lead Ads)
# =========================================================
# Single-account / legacy mode (still used as a fallback):
META_SYSTEM_TOKEN=
META_APP_ID=
META_APP_SECRET=
META_PAGE_ID=
META_AD_ACCOUNT_ID=

# Multi-account mode (preferred when you have several ad accounts).
# When META_AD_ACCOUNTS is set, the API queries every listed ad account and
# merges the result. For each account the token resolution order is:
#   META_ACCESS_TOKEN_<adAccountId>  →  META_ACCESS_TOKEN  →  META_SYSTEM_TOKEN
META_ACCESS_TOKEN=
META_AD_ACCOUNTS=
# Per-account overrides (one line per account id):
# META_ACCESS_TOKEN_<adAccountId>=

# Optional comma-separated list of form IDs that aren't reachable via
# /me/accounts or by scanning ad creatives (e.g. draft forms). They are
# fetched by direct ID using whichever configured token works.
META_EXTRA_FORM_IDS=

# =========================================================
# Google Sheets (OAuth 2.0)
# =========================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# =========================================================
# WATI (WhatsApp)
# =========================================================
WATI_API_ENDPOINT=
WATI_ACCESS_TOKEN=

# =========================================================
# Telegram error alerts (optional)
# =========================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =========================================================
# Next.js Web (frontend/)
# =========================================================
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET="REPLACE_WITH_LONG_RANDOM_STRING"
