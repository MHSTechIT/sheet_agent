# =========================================================
# Application encryption key (32 random bytes, base64)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# =========================================================
APP_ENC_KEY="REPLACE_WITH_BASE64_32_BYTES"

# =========================================================
# NestJS API (apps/api)
# =========================================================
API_PORT=4000
API_HOST=0.0.0.0
WEB_ORIGIN=http://localhost:3000

# Where JSON state files live. Default: <repo-root>/data
# DATA_DIR=/var/lib/sheet-agent

# Owner login (the only account; password-only sign in)
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=change-me

# JWT
JWT_SECRET="REPLACE_WITH_LONG_RANDOM_STRING"
JWT_EXPIRES_IN=7d

# =========================================================
# Next.js Web (apps/web)
# =========================================================
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET="REPLACE_WITH_LONG_RANDOM_STRING"
