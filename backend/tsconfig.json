{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "ES2022",
    "outDir": "dist",
    "rootDir": "src",
    "declaration": false,
    "sourceMap": false,
    "useDefineForClassFields": false,
    "baseUrl": ".",
    "incremental": true,
    "strictPropertyInitialization": false
  },
  "include": ["src/**/*"]
}
